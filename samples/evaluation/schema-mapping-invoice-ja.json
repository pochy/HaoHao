{
  "dataset": "schema-mapping-invoice-ja",
  "version": 1,
  "description": "Japanese invoice schema mapping evaluation cases for local vector / hybrid candidate search.",
  "domain": "invoice",
  "schemaType": "ap_invoice",
  "language": "ja",
  "source": "Hand-labeled synthetic cases based on realistic Japanese AP invoice exports and OCR-derived column names.",
  "acceptanceGates": {
    "minimumCasesBeforeBroadRollout": 100,
    "starterCases": 30,
    "top1Accuracy": 0.75,
    "top3Accuracy": 0.9,
    "noCandidatePrecision": 0.8,
    "maxFalsePositiveRate": 0.08
  },
  "targetColumns": [
    "invoice_number",
    "invoice_date",
    "due_date",
    "vendor_name",
    "vendor_registration_number",
    "subtotal_amount",
    "tax_amount",
    "total_amount",
    "currency",
    "purchase_order_number"
  ],
