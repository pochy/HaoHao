        "invoice_id",
        "伝票No",
        "伝票番号",
        "発票番号",
        "請求書No"
      ],
      "examples": [
        "INV-2026-00045",
        "A-1042",
        "2026-05-001"
      ]
    },
    {
      "targetColumn": "invoice_date",
      "description": "請求書の発行日。請求日、発行日、Invoice Date などから対応する。",
