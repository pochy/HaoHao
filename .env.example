APP_NAME="HaoHao API"
APP_VERSION=0.1.0
HTTP_PORT=8080
LOG_LEVEL=info
LOG_FORMAT=json
METRICS_ENABLED=true
METRICS_PATH=/metrics

SECURITY_HEADERS_ENABLED=true
SECURITY_CSP="default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'"
SECURITY_HSTS_ENABLED=false
SECURITY_HSTS_MAX_AGE=31536000
MAX_REQUEST_BODY_BYTES=10485760
TRUSTED_PROXY_CIDRS=
CORS_ALLOWED_ORIGINS=

OTEL_TRACING_ENABLED=false
OTEL_SERVICE_NAME=haohao
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_TRACES_SAMPLER_RATIO=0.1

APP_BASE_URL=http://127.0.0.1:8080
FRONTEND_BASE_URL=http://127.0.0.1:5173

DATABASE_URL=postgres://haohao:haohao@127.0.0.1:5432/haohao?sslmode=disable

AUTH_MODE=local
ZITADEL_ISSUER=
ZITADEL_CLIENT_ID=
ZITADEL_CLIENT_SECRET=
ZITADEL_REDIRECT_URI=http://127.0.0.1:8080/api/v1/auth/callback
ZITADEL_POST_LOGOUT_REDIRECT_URI=http://127.0.0.1:5173/login
ZITADEL_SCOPES="openid profile email"

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

SESSION_TTL=24h
LOGIN_STATE_TTL=10m

EXTERNAL_EXPECTED_AUDIENCE=haohao-external
EXTERNAL_REQUIRED_SCOPE_PREFIX=
EXTERNAL_REQUIRED_ROLE=external_api_user
EXTERNAL_ALLOWED_ORIGINS=

M2M_EXPECTED_AUDIENCE=haohao-m2m
M2M_REQUIRED_SCOPE_PREFIX=m2m:

DOWNSTREAM_TOKEN_ENCRYPTION_KEY=
DOWNSTREAM_TOKEN_KEY_VERSION=1
DOWNSTREAM_REFRESH_TOKEN_TTL=2160h
DOWNSTREAM_ACCESS_TOKEN_SKEW=30s
DOWNSTREAM_DEFAULT_SCOPES=offline_access

SCIM_BASE_PATH=/api/scim/v2
SCIM_BEARER_AUDIENCE=scim-provisioning
SCIM_REQUIRED_SCOPE=scim:provision

READINESS_TIMEOUT=2s
READINESS_CHECK_ZITADEL=false

SCIM_RECONCILE_ENABLED=false
SCIM_RECONCILE_INTERVAL=1h
SCIM_RECONCILE_TIMEOUT=30s
SCIM_RECONCILE_RUN_ON_STARTUP=false

OUTBOX_WORKER_ENABLED=true
OUTBOX_WORKER_INTERVAL=5s
OUTBOX_WORKER_TIMEOUT=10s
OUTBOX_WORKER_BATCH_SIZE=20
OUTBOX_WORKER_MAX_ATTEMPTS=8

IDEMPOTENCY_TTL=24h

EMAIL_DELIVERY_MODE=log
EMAIL_FROM=no-reply@example.com

INVITATION_TTL=168h

FILE_LOCAL_DIR=.data/files
FILE_MAX_BYTES=10485760
FILE_ALLOWED_MIME_TYPES=text/plain,text/csv,application/json,image/png,image/jpeg

RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_PER_MINUTE=20
RATE_LIMIT_BROWSER_API_PER_MINUTE=120
RATE_LIMIT_EXTERNAL_API_PER_MINUTE=120

TENANT_DEFAULT_FILE_QUOTA_BYTES=104857600
DATA_EXPORT_TTL=168h

DATA_LIFECYCLE_ENABLED=true
DATA_LIFECYCLE_INTERVAL=1h
DATA_LIFECYCLE_TIMEOUT=30s
DATA_LIFECYCLE_RUN_ON_STARTUP=false
OUTBOX_RETENTION=720h
NOTIFICATION_RETENTION=4320h
FILE_DELETED_RETENTION=720h
FILE_PURGE_BATCH_SIZE=50
FILE_PURGE_LOCK_TIMEOUT=15m

WEBHOOK_SECRET_ENCRYPTION_KEY=
WEBHOOK_SECRET_KEY_VERSION=1
WEBHOOK_HTTP_TIMEOUT=10s
SUPPORT_ACCESS_MAX_DURATION=1h

COOKIE_SECURE=false
DOCS_AUTH_REQUIRED=false
ENABLE_LOCAL_PASSWORD_LOGIN=true
